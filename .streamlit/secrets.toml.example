# Copy this file to `.streamlit/secrets.toml` for LOCAL development,
# or paste these lines into the "Secrets" box on Streamlit Community Cloud
# (App → Settings → Secrets) for DEPLOYMENT.
#
# Streamlit exposes every top-level key below as an environment variable,
# which is exactly what online_voting_system.py reads via os.environ.
#
# NEVER commit the real secrets.toml — it is git-ignored on purpose.

# Full Postgres connection string from Supabase or Neon.
# Supabase: Project → Connect → "Connection string" → URI (use the pooler / port 6543 host).
# Make sure it ends with ?sslmode=require
DATABASE_URL = "postgresql://USER:PASSWORD@HOST:PORT/DBNAME?sslmode=require"

# Secret code required to self-register an admin account. Change this!
ADMIN_SETUP_CODE = "CollegeVote#2026"
